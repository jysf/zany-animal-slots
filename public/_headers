/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Strict-Transport-Security: max-age=15552000
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=()
  Content-Security-Policy: default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self'; media-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'

# HTML entry points revalidate every load so a new deploy is picked up
# immediately. Cache-Control is kept OFF the /* block on purpose: Cloudflare
# Workers Static Assets MERGES matching _headers rules (it does not let the more
# specific rule win), so a no-cache on /* would be appended onto /assets/* and
# defeat the immutable rule below. Scope no-cache to the HTML paths instead.
/
  Cache-Control: no-cache
/index.html
  Cache-Control: no-cache

# Content-hashed build assets — safe to cache forever, never revalidate.
/assets/*
  Cache-Control: public, max-age=31536000, immutable
